# AutoResearch API Configuration
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env

# Required
AUTORESEARCH_API_URL=http://your-api-endpoint:8000/path
AUTORESEARCH_USERNAME=your_username
AUTORESEARCH_USERID=your_userid
AUTORESEARCH_TOKEN=your_token

# Optional (defaults shown)
# AUTORESEARCH_MODEL_NAME=gemini-3-pro-preview
# AUTORESEARCH_MODEL_TYPE=openai
